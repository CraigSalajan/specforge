# SpecForge benchmark configuration. Copy this file to `bench/.env` and fill it in.
# `bench/.env` is gitignored. Real shell env vars override anything set here.

# --- Required: the OpenAI-compatible model endpoint under test ---
SPECFORGE_BENCH_BASE_URL=https://api.openai.com/v1
SPECFORGE_BENCH_API_KEY=sk-replace-me
SPECFORGE_BENCH_MODEL=gpt-4o-mini

# --- Optional ---
# Temp vault dir for write_file/read tools (default: a fresh OS temp dir)
#SPECFORGE_BENCH_VAULT=
# CSV of tool names to NOT advertise to the model, e.g. search_vault,use_skill
#SPECFORGE_BENCH_DISABLED_TOOLS=
# System-prompt context budget in chars (default 8000)
#SPECFORGE_BENCH_MAX_CONTEXT_CHARS=8000
# Per-request timeout in ms (default 60000)
#SPECFORGE_BENCH_TIMEOUT_MS=60000
# Path to the built Node runner (default: ../dist/bench/harness-runner.mjs vs the crate)
#SPECFORGE_BENCH_RUNNER=
# Node executable (default: node)
#SPECFORGE_BENCH_NODE=
# Cases dir (default: <crate>/cases)
#SPECFORGE_BENCH_CASES=
# Results dir for persisted runs/report.html (default: <crate>/results)
#SPECFORGE_BENCH_RESULTS=

# --- Optional: upload each run to the EvalForge dashboard (evalforge.ai) ---
# Set BOTH to auto-upload every run so it shows up online. Leave them unset to
# skip uploading entirely (default). Get them by signing in at evalforge.ai,
# creating/opening a Project (copy its Project ID — a non-secret UUID), then
# minting an API key under your account settings.
# Project ID is non-secret; the API key (sk-eval-…) is a SECRET — it stays in
# this gitignored file, never commit it.
#EVALFORGE_PROJECT_ID=00000000-0000-0000-0000-000000000000
#EVALFORGE_API_KEY=sk-eval-...
